# Frontend (Next.js) env — copy to .env.local (gitignored).
# Every variable here is consumed by app/app/_lib/* at build/runtime.
# Anything prefixed NEXT_PUBLIC_ is inlined into the client bundle.
#
# For local dev: keep backend URL pointing at localhost.
# For Vercel production: set NEXT_PUBLIC_BACKEND_URL (and any keys you
# want to override) in the Vercel project's Environment Variables UI,
# e.g. NEXT_PUBLIC_BACKEND_URL=https://senthos-backend-production.up.railway.app

# --- Backend base URL ----------------------------------------------------
# Used by app/lib/api.ts + app/app/_lib/tokens.ts for every fetch(). Both
# vars exist because server-side code reads BACKEND_URL while client-side
# code needs NEXT_PUBLIC_BACKEND_URL (must start with NEXT_PUBLIC_ to ship
# to the browser). Keep them in sync.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001

# --- Solana cluster + RPC -----------------------------------------------
# Drives WalletProviders, the wallet-bridge deposit-confirm poller, and
# the useUsdcBalance hook. Devnet is the default; override both if you
# switch clusters. The cluster flag is used when composing explorer URLs
# so confirmations deep-link to the right cluster view.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# --- USDC mint (Circle devnet by default) -------------------------------
# The wallet-bridge fetches the user's ATA for this mint to display
# their live USDC balance, and the backend uses the same mint when
# building deposit transactions. If you switch to mainnet or a custom
# mint, change BOTH this and backend/.env's USDC_MINT to match.
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
