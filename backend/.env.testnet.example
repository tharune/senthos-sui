PORT=3001

# ---------- Supabase ----------
# Fill these with your own Supabase project values if you enable the
# persisted indexer routes. Local Sui mode can run without Supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- External APIs ----------
POLYMARKET_API_URL=https://clob.polymarket.com
FRONTEND_URL=http://localhost:3000

# ---------- Solana — TESTNET ----------
# SOLANA_CLUSTER drives default RPC + USDC_MINT behavior in
# backend/src/solana/anchor.ts.
SOLANA_CLUSTER=testnet

# Public testnet RPC. For higher rate limits in production, swap in a
# Triton/QuickNode testnet URL.
SOLANA_RPC_URL=https://api.testnet.solana.com

# Program IDs — testnet deployment. These match the keypairs in
# target/deploy/ and the declare_id!() in programs/*/src/lib.rs. Devnet
# uses different IDs (E77R7… / 4Nnrpe…) whose keypairs were lost in the
# 33d2edd → 88c0dad transition; that's fine because devnet is already
# deployed and immutable.
TRAXIS_VAULT_PROGRAM_ID=DY7NAimrQZY7SxveXTb38XN7H69wAXjZZj8DRHto4Aat
TRAXIS_PPN_PROGRAM_ID=3wDHsr9EnWkF968zYmSsj4hShNkAyFV6r7zxPrjqWNsp

# Mock USDC mint on testnet (Circle does NOT issue USDC on testnet, so we
# deployed our own 6-decimal SPL mint). Set AUTHORITY_KEYPAIR to a local
# keypair that owns the mint authority before using /api/dev/airdrop-mock-usdc.
USDC_MINT=G1zoPvosbZad3CYrpHHTWFACoJh8T4XVBYB2YBjexTbK

# Treasury / fee recipient wallet. Hardcoded to the wallet that
# initialized the existing 11 testnet vaults — the vault accounts have
# this pubkey baked in via initialize_vault, and deposit/redeem
# constraints reject any other fee_recipient_ata. Change ONLY if you're
# initializing brand-new vaults from scratch.
FEE_RECIPIENT=38fe3phREhkZNHmeAaZg1snxNafpFkPTivST465SYY5f

# Authority keypair. This must be a local file path or JSON-array secret key.
# Never commit this value with real key material.
AUTHORITY_KEYPAIR=

# ---------- Helius ----------
# Helius supports mainnet + devnet, NOT testnet. Leave empty.
HELIUS_API_KEY=

# ---------- Anthropic (Claude API — portfolio composer) ----------
# Optional; the portfolio-construct route degrades gracefully without it.
ANTHROPIC_API_KEY=
