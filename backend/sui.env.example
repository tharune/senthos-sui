PORT=3001
FRONTEND_URL=http://localhost:3000
POLYMARKET_API_URL=https://clob.polymarket.com

# Sui testnet deployment
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_CLI=sui
SUI_KEYSTORE_PATH=/path/to/.sui/sui_config
SUI_ACTIVE_ADDRESS=0xee770af6c184b101aa91fab0fffdee62c1fecc86fd3e681d978336bf70eead79
SUI_PACKAGE_ID=0xbb86d6dd74eaa2277f0aac7b2649e094ce4a92697baf3cf08e4fa5b842452cf8
SUI_MARKET_MODULE=prediction_market
SUI_MARKET_ADMIN_CAP_ID=0xbfebc54352926144ade0f20995b9c0e31e4689929d04b038e49ff0c544b981fa

# Testnet mock-USDC mint authority. The local Sui key that owns this TreasuryCap
# can mint test mUSDC; do not commit private keys or recovery phrases.
MOCK_USDC_TYPE=0xbb86d6dd74eaa2277f0aac7b2649e094ce4a92697baf3cf08e4fa5b842452cf8::mock_usdc::MOCK_USDC
MOCK_USDC_TREASURY_CAP_ID=0x5e50d50e6a82fd9583b87b31b5647cca49cc4d4aa580df7f8d12b56f4b63f90e
MOCK_USDC_METADATA_ID=0x55777a6792e90559480d91dfae8871c950f8ea3683a6ba3c051677b5819e5ecc
MOCK_USDC_DECIMALS=6

# --- DeepBook Predict (testnet) -------------------------------------------
# On-chain wiring for the DeepBook Predict track. Every value has a baked-in
# testnet default (see src/services/predict/config.ts); override only to repoint
# at a new deployment. IDs below are the live predict-testnet-4-16 deployment.
PREDICT_NETWORK=testnet
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
# Predict's gated quote asset (NOT the regular testnet USDC). Faucet-gated:
# minted by a Mysten-owned TreasuryCap. Request dUSDC via the DeepBook Predict
# form: https://tally.so/r/Xx102L  (needed only for writes; reads/previews don't).
PREDICT_DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# Signer for Predict writes (mint/redeem/supply/withdraw). Optional: read and
# devInspect endpoints work with no key. If unset, the loader falls back to the
# Sui CLI keystore at SUI_KEYSTORE_PATH (matched against SUI_ACTIVE_ADDRESS).
# Accepts bech32 `suiprivkey...` or base64 [flag||secret]. DO NOT COMMIT A REAL KEY.
PREDICT_SIGNER_PRIVATE_KEY=

# Leave Supabase unset for local Sui mode; DB-backed legacy endpoints degrade.
SUPABASE_URL=
SUPABASE_ANON_KEY=
ANTHROPIC_API_KEY=
