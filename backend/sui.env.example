SUI_MARKET_ADMIN_CAP_ID=0xbfebc54352926144ade0f20995b9c0e31e4689929d04b038e49ff0c544b981fa

# Testnet mock-USDC mint authority. The local Sui key that owns this TreasuryCap
# can mint test mUSDC; do not commit private keys or recovery phrases.
MOCK_USDC_TYPE=0xbb86d6dd74eaa2277f0aac7b2649e094ce4a92697baf3cf08e4fa5b842452cf8::mock_usdc::MOCK_USDC
MOCK_USDC_TREASURY_CAP_ID=0x5e50d50e6a82fd9583b87b31b5647cca49cc4d4aa580df7f8d12b56f4b63f90e
MOCK_USDC_METADATA_ID=0x55777a6792e90559480d91dfae8871c950f8ea3683a6ba3c051677b5819e5ecc
MOCK_USDC_DECIMALS=6

# Leave Supabase unset for local Sui mode; DB-backed legacy endpoints degrade.
SUPABASE_URL=
SUPABASE_ANON_KEY=
ANTHROPIC_API_KEY=
