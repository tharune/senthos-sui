PORT=3001

# ---------- Supabase ----------
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------- External APIs ----------
POLYMARKET_API_URL=https://clob.polymarket.com
FRONTEND_URL=http://localhost:3000

# ---------- Solana ----------
# Devnet RPC (Helius recommended for higher rate limits; replace ?api-key=... with yours)
SOLANA_RPC_URL=https://api.devnet.solana.com
# Program IDs (written by scripts/deploy-devnet.sh after `anchor deploy`)
TRAXIS_VAULT_PROGRAM_ID=TRAXVau1tProgram11111111111111111111111111
TRAXIS_PPN_PROGRAM_ID=TRAXPPNpRogramm1111111111111111111111111111
# Circle devnet USDC (keep as-is unless you mint your own test USDC)
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Treasury / fee recipient wallet — can be any keypair. Initialize its USDC ATA before first deposit.
FEE_RECIPIENT=replace_with_treasury_pubkey

# Authority keypair — used by the backend to sign resolve_leg / finalize_vault / initialize_vault.
# EITHER a path to a JSON file ("~/.config/solana/id.json")
# OR a JSON array of 64 secret bytes ("[1,2,3,...]").
# Do NOT commit the actual keypair.
AUTHORITY_KEYPAIR=~/.config/solana/id.json

# ---------- Helius ----------
HELIUS_API_KEY=replace_with_helius_key
# Set in Helius dashboard to point at your deployed backend:
#   https://<your-railway-app>.up.railway.app/api/webhook/helius

# ---------- Anthropic (Claude API — portfolio composer) ----------
# Used by POST /api/portfolio/construct to generate portfolio allocations.
# Get a key at https://console.anthropic.com/. Endpoint fails 500 if missing.
ANTHROPIC_API_KEY=
