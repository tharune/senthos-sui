# Frontend (Next.js) env for TESTNET.
# Copy to .env.local when you want to point the UI at testnet.
# Or drive it via SWITCH-CLUSTER.command testnet (auto-copies for you).

# --- Backend base URL ---------------------------------------------------
# Same as devnet locally — the backend picks up its own cluster from
# backend/.env. For Vercel/production, point at the testnet-configured
# Railway deployment.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001

# --- Solana cluster + RPC -----------------------------------------------
# Drives WalletProviders' ConnectionProvider endpoint, the wallet-bridge
# deposit-confirm poller, useUsdcBalance, and explorer links. Phantom
# users must also switch their wallet to "Testnet" in Phantom Settings
# → Developer Settings → Testnet Mode.
NEXT_PUBLIC_SOLANA_CLUSTER=testnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.testnet.solana.com

# --- Mock USDC mint (testnet) ------------------------------------------
# The shared 6-decimal SPL mint we deployed for testnet. Configure the backend
# with a local mint-authority keypair before using the faucet route.
NEXT_PUBLIC_USDC_MINT=G1zoPvosbZad3CYrpHHTWFACoJh8T4XVBYB2YBjexTbK
